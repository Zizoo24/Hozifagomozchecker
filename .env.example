# Moz API Credentials (optional if using Semrush)
# Get yours at https://moz.com/products/api/keys
MOZ_ACCESS_ID=your_moz_access_id_here
MOZ_SECRET_KEY=your_moz_secret_key_here

# Semrush API Key (optional if using Moz)
# Get yours at https://www.semrush.com/api/
SEMRUSH_API_KEY=your_semrush_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000
